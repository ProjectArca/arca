; ModuleID = 'main_module'
target triple = "aarch64-apple-darwin"

declare i32 @puts(i8*)
declare i8* @malloc(i64)
declare void @free(i8*)

define void @main() {
bb_0:
  %r0 = alloca i64
  store i64 100, i64* %r0
  %r1 = alloca i64
  %r2 = load i64, i64* %r0
  store i64 %r2, i64* %r1
  %r3 = load i64, i64* %r1
  %r4 = call i64 @println(i64 %r3)
  ret void
}

