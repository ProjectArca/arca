; ModuleID = 'main_module'
target triple = "aarch64-apple-darwin"

declare i32 @puts(i8*)
declare i8* @malloc(i64)
declare void @free(i8*)

define void @main() {
bb_0:
  %r0 = alloca i64
  store i64 0, i64* %r0
  %r1 = alloca i64
  store i64 0, i64* %r1
  br label %bb_1
bb_1:
  %r2 = load i64, i64* %r0
  %r3 = add i64 %r2, 4
  br i1 %r3, label %bb_3, label %bb_5
bb_3:
  %r4 = load i64, i64* %r1
  %r5 = load i64, i64* %r0
  %r6 = add i64 %r4, %r5
  store i64 %r6, i64* %r1
  %r7 = load i64, i64* %r0
  %r8 = add i64 %r7, 1
  store i64 %r8, i64* %r0
  br label %bb_4
bb_4:
  br label %bb_1
bb_5:
  %r9 = load i64, i64* %r1
  %r10 = call i64 @println(i64 %r9)
  ret void
}

