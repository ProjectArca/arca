; ModuleID = 'main_module'
target triple = "aarch64-apple-darwin"

declare i32 @puts(i8*)
declare i8* @malloc(i64)
declare void @free(i8*)

define void @main() {
bb_4:
  %r9 = alloca i64
  %r10 = call i64 @fib(i64 10)
  store i64 %r10, i64* %r9
  %r11 = load i64, i64* %r9
  %r12 = call i64 @println(i64 %r11)
  ret void
}

define i64 @fib() {
bb_0:
  %r1 = add i64 %r0, 1
  %r2 = alloca i64
  br i1 %r1, label %bb_1, label %bb_2
bb_1:
  store i64 %r0, i64* %r2
  br label %bb_3
bb_2:
  %r3 = sub i64 %r0, 1
  %r4 = call i64 @fib(i64 %r3)
  %r5 = sub i64 %r0, 2
  %r6 = call i64 @fib(i64 %r5)
  %r7 = add i64 %r4, %r6
  store i64 %r7, i64* %r2
  br label %bb_3
bb_3:
  %r8 = load i64, i64* %r2
  ret i64 %r8
}

