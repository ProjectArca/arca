; ModuleID = 'main_module'
target triple = "aarch64-apple-darwin"

declare i32 @puts(i8*)
declare i8* @malloc(i64)
declare void @free(i8*)

define i64 @sum_items() {
bb_0:
  %r2 = add i64 %r1, 0
  %r3 = alloca i64
  br i1 %r2, label %bb_1, label %bb_2
bb_1:
  store i64 0, i64* %r3
  br label %bb_3
bb_2:
  %r4 = sub i64 %r1, 1
  %r5 = call i64 @sum_items(i64 %r0, i64 %r4)
  %r6 = add i64 %r0, %r5
  store i64 %r6, i64* %r3
  br label %bb_3
bb_3:
  %r7 = load i64, i64* %r3
  ret i64 %r7
}

define void @main() {
bb_4:
  %r8 = alloca i64
  %r9 = call i64 @sum_items(i64 2, i64 3)
  store i64 %r9, i64* %r8
  %r10 = load i64, i64* %r8
  %r11 = call i64 @println(i64 %r10)
  ret void
}

