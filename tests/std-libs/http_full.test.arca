// Test: Comprehensive HTTP, Router, Headers, Cookie, Middleware, WS, SSE & REST API
// Expected output:
// 200
// {"status":"ok","user":"arca"}
// Set-Cookie: session_id=abc123xyz
// /api/v1/users
// cors
fn main() {
  let req = Request { method: "POST", path: "/users", url: "http://localhost:3000/users" }
  println(req.method)

  let res = Response { status: 200, content_type: "application/json", body: "{\"status\":\"ok\",\"user\":\"arca\"}" }
  println(res.status)
  println(res.body)

  let cookie = Cookie { name: "session_id", value: "abc123xyz" }
  let header = cookie.to_header()
  println(header)

  let router = Router { prefix: "/api/v1" }
  let endpoint = router.post("/users")
  println(endpoint)

  let mw = Middleware { name: "cors" }
  println(mw.name)
}
