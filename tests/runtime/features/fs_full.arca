// Test: std/fs — rename, copy, metadata
// Expected output:
// 0
// 0
// [non-zero size integer]
fn main() {
  let r = File.rename("/tmp/nonexistent1", "/tmp/nonexistent2")
  println(r)
  let c = File.copy("/tmp/nonexistent1", "/tmp/nonexistent2")
  println(c)
  let m = File.metadata("/tmp")
  println(m)
}
