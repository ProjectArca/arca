// Patch 6: std/fs operations
fn main() {
  let r = File.write("/tmp/arca_test.txt", "hello arca fs")
  println(File.exists("/tmp/arca_test.txt"))
  let content = File.read("/tmp/arca_test.txt")
  println(content)
  let cr = File.copy("/tmp/arca_test.txt", "/tmp/arca_copy.txt")
  println(File.exists("/tmp/arca_copy.txt"))
}
