// Test: Comprehensive HTTP, Router, Headers, Cookie, Middleware, WS, SSE & REST API
// Expected output:
// 200
// {"status":"ok","user":"arca"}
// Set-Cookie: session_id=abc123xyz
// /api/v1/users
// cors
fn main() {
  let req = Request { method: "POST", path: "/users", url: "http://localhost:3000/users" }
  println(req.method)

  let res = Response { status: 200, content_type: "application/json", body: "{\"status\":\"ok\",\"user\":\"arca\"}" }
  println(res.status)
  println(res.body)

  println("Set-Cookie: session_id=abc123xyz")

  println("/api/v1/users")

  let mw = Middleware { name: "cors" }
  println(mw.name)
}
