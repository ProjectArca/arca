  let s = HashSet { handle: 0 }
  println(s.handle)
  let q = Queue { handle: 0 }
  println(q.handle)
  let d = Deque { handle: 0 }
  println(d.handle)
  let h = BinaryHeap { handle: 0 }
  println(h.handle)
  let l = LinkedList { handle: 0 }
  println(l.handle)
}
