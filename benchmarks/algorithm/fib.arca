// Arca Fibonacci Benchmark
// Clean high-level application code using std/time

import { Instant } from "std/time"

fn fib(n: i32) -> i32 {
  if n <= 1 { n }
  else { fib(n - 1) + fib(n - 2) }
}

fn main() {
  let start = Instant.now()
  let result = fib(45)
  let elapsed = start.elapsed_ms()
  print("Arca fib(45) = ")
  print(result)
  print(" (")
  print(elapsed)
  println("ms)")
}
