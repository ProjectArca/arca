// Arca Standard Library - Time (std/time)
// Provides Bun/Go style high-level Instant & Duration primitives.

struct Instant {
  start: i64
}

extend Instant {
  fn now() -> i64 {
    Instant.now()
  }

  fn elapsed_ms(self) -> i64 {
    self.elapsed_ms()
  }

  fn elapsed_ns(self) -> i64 {
    self.elapsed_ns()
  }
}
