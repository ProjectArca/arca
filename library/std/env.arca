// Arca Standard Environment (std/env)

extern fn arca_env_get(name: string) -> string
extern fn arca_env_set(name: string, value: string) -> i64
extern fn arca_current_dir() -> string
extern fn arca_env_args(index: i32) -> string

fn get(name: string) -> string {
  arca_env_get(name)
}

fn set(name: string, value: string) -> i64 {
  arca_env_set(name, value)
}

fn current_dir() -> string {
  arca_current_dir()
}

fn args(index: i32) -> string {
  arca_env_args(index)
}
